# ─── HackerAI Configuration ──────────────────────────────
# Copy ke .env dan isi sesuai kebutuhan.
# Semua setting bisa via env variable atau .env file.

# ─── API Keys ────────────────────────────────────────────
SHODAN_API_KEY=
VIRUSTOTAL_API_KEY=
GITHUB_TOKEN=
NVD_API_KEY=
HUNTER_API_KEY=

# ─── Network ─────────────────────────────────────────────
HAI_TIMEOUT=10               # Default timeout (detik)
HAI_THREADS=50               # Max concurrent threads
HAI_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36
HAI_PROXY=                   # Proxy: http://127.0.0.1:8080

# ─── Output ──────────────────────────────────────────────
HAI_VERBOSE=0                # 1 = verbose / debug output
HAI_COLOR=1                  # 1 = colored output
HAI_LOG_LEVEL=INFO           # DEBUG / INFO / WARNING / ERROR
HAI_LOG_FILE=logs/hackerai.log

# ─── Tool Defaults ───────────────────────────────────────
HAI_PORT_RANGE=1-1000
HAI_SQLI_TIMEOUT=5
HAI_SSH_PORT=22
HAI_SSH_TIMEOUT=5
HAI_OSINT_THREADS=20

# ─── Optional: Custom Wordlist Path ──────────────────────
# HAI_WORDLIST=/path/to/wordlist.txt
